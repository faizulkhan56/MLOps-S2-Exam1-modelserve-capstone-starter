{
  "uid": "modelserve-overview",
  "title": "ModelServe — Overview",
  "tags": ["modelserve", "phase-7"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Prediction latency (p50 / p95 / p99)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "p50",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(prediction_duration_seconds_bucket{job=\"modelserve-api\"}[$__rate_interval])))"
        },
        {
          "refId": "B",
          "legendFormat": "p95",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(prediction_duration_seconds_bucket{job=\"modelserve-api\"}[$__rate_interval])))"
        },
        {
          "refId": "C",
          "legendFormat": "p99",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(prediction_duration_seconds_bucket{job=\"modelserve-api\"}[$__rate_interval])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "/predict request rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "req/s",
          "expr": "sum(rate(prediction_requests_total{job=\"modelserve-api\"}[$__rate_interval]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Prediction error rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "errors / requests",
          "expr": "sum(rate(prediction_errors_total{job=\"modelserve-api\"}[$__rate_interval])) / clamp_min(sum(rate(prediction_requests_total{job=\"modelserve-api\"}[$__rate_interval])), 1e-9)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Served model (from metrics)",
      "gridPos": { "h": 7, "w": 10, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "model_version_info{job=\"modelserve-api\"}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "inspect": false, "filterable": false }
        },
        "overrides": []
      },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Feast online hit / (hit + miss) ratio",
      "gridPos": { "h": 7, "w": 14, "x": 10, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "hit ratio",
          "expr": "sum(rate(feast_online_store_hits_total{job=\"modelserve-api\"}[$__rate_interval])) / clamp_min(sum(rate(feast_online_store_hits_total{job=\"modelserve-api\"}[$__rate_interval])) + sum(rate(feast_online_store_misses_total{job=\"modelserve-api\"}[$__rate_interval])), 1e-9)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Prometheus scrape: API up",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"modelserve-api\"}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background"
      }
    }
  ]
}
