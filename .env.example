# Copy to .env and adjust. Never commit .env.
# Used by: docker compose, local scripts, FastAPI (later phases)

# ---- PostgreSQL (MLflow backend store) — consumed by: postgres, mlflow
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# ---- Redis (Feast online store) — consumed by: redis, app (Feast)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---- MLflow — consumed by: training scripts, app
# In Compose, use the internal service name for clients inside the network.
MLFLOW_TRACKING_URI=http://mlflow:5000
# Public URL for browser on host (optional)
MLFLOW_PUBLIC_URI=http://localhost:5000

# ---- API — consumed by: api container
API_HOST=0.0.0.0
API_PORT=8000
# Registry model name and stage (Phases 3+)
MLFLOW_MODEL_NAME=modelserve_classifier
MLFLOW_MODEL_STAGE=Production

# ---- Feast — consumed by: materialize script, app (Phases 4+)
# Path inside the api container; compose mounts ./feast_repo
FEAST_REPO_PATH=/app/feast_repo

# ---- Prometheus / Grafana — consumed by: compose (optional overrides)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me

# ---- AWS (placeholder for Phases 6+; not required for local stack)
AWS_DEFAULT_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
